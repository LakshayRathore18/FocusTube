# Copy this to .env.local and fill in your values
# NEVER commit .env.local
DATABASE_URL=""

AUTH_SECRET=""                    # generate: openssl rand -base64 32
AUTH_TRUST_HOST=true                # required for Vercel/reverse proxies
# ⚠️ Change NEXTAUTH_URL below to your production URL when deploying
NEXTAUTH_URL="https://focustube.vercel.app"

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

YOUTUBE_API_KEY=""

GEMINI_API_KEY=""   # Google Gemini API key
GEMINI_MODEL="gemini-3.1-flash-lite"   # Override default model (default set in src/lib/ai/gemini.ts)

# Supadata.ai (YouTube transcript API — works from Vercel server IPs)
# Get free key at: https://supadata.ai (100 free credits/month)
SUPADATA_API_KEY=