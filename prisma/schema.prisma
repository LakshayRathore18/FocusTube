// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Note: In Prisma 7, connection URL is configured in prisma.config.ts, not here
}

// ─────────────────────────────────────────────────────────────────────────────
// AUTH TABLES (NextAuth / Auth.js v5 — JWT sessions, no Session table needed)
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  courses  Course[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ─────────────────────────────────────────────────────────────────────────────
// CORE APP TABLES
// ─────────────────────────────────────────────────────────────────────────────

// One imported YouTube playlist, owned by a user
model Course {
  id                String   @id @default(cuid())
  userId            String
  youtubePlaylistId String
  title             String
  thumbnailUrl      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos Video[]

  // A user can only import the same playlist once
  @@unique([userId, youtubePlaylistId])
}

// One video in a course.
// Holds per-user watch state directly (no join table needed —
// Video already belongs to exactly one user via Course → User).
model Video {
  id                 String      @id @default(cuid())
  courseId           String
  youtubeVideoId     String
  title              String
  position           Int         // Order within the playlist (0-indexed)
  durationSeconds    Int?
  thumbnailUrl       String?
  isAvailable        Boolean     @default(true) // false = private/deleted on YouTube
  status             VideoStatus @default(not_started)
  lastWatchedSeconds Int?        // Resume playback position
  completedAt        DateTime?   // Set when status transitions to completed
  aiContentUnlockedAt DateTime?  // Set when the user first generates (or unlocks existing) AI content for this video
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  notes  Note[]

  // A video can only appear once per course
  @@unique([courseId, youtubeVideoId])
  // Indexed for AIContent lookups (many videos share same YT video ID across users)
  @@index([youtubeVideoId])
}

enum VideoStatus {
  not_started
  in_progress
  completed
}

// AI-generated content — SHARED across all users, keyed by youtubeVideoId.
// Per-user unlock tracking is done via Video.aiContentUnlockedAt instead.
// This preserves the cost savings of a single AI generation per video.
model AIContent {
  id             String          @id @default(cuid())
  youtubeVideoId String          @unique
  transcript     String?         @db.Text
  summary        String?         @db.Text
  quiz           Json?           // { questions: [{ question, options: string[], answer: number }] }
  status         AIContentStatus @default(pending)
  attempts       Int             @default(0)  // Number of generation attempts
  lastAttemptedAt DateTime?      // Last attempt timestamp
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum AIContentStatus {
  pending // AI generation in progress
  ready   // Content available
  failed  // Generation failed — safe to retry
}

// Free-text notes on a video.
// No userId — ownership implied via Note → Video → Course → User.
// One note per video — enforced at the DB level.
model Note {
  id        String   @id @default(cuid())
  videoId   String   @unique  // One note per video
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
}
